{
  "name": "gagnaire-portfolio",
  "version": "1.0.0",
  "description": "Monorepo - Frontend React + Backend ExpressJS",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "postinstall": "(test -f backend/scripts/generate-lock.sh && npm run lock:backend) || true; (test -f frontend/scripts/generate-lock.sh && npm run lock:frontend) || true",
    "dev": "npm run dev --workspaces --if-present",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspaces --if-present",
    "build:frontend": "npm run build --workspace=frontend",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "typecheck:frontend": "npm run typecheck --workspace=frontend",
    "lint": "npm run lint --workspaces --if-present",
    "lint:frontend": "npm run lint --workspace=frontend",
    "lint:backend": "npm run lint --workspace=backend",
    "test": "npm run test --workspaces --if-present",
    "test:backend": "npm run test --workspace=backend",
    "install:all": "npm install",
    "docker:lock": "npm run lock:backend && npm run lock:frontend",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:dev:detach": "npm run docker:lock && docker compose -f docker-compose.dev.yml up --build -d",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:prod": "npm run docker:lock && docker compose up --build",
    "docker:prod:detach": "npm run docker:lock && docker compose up --build -d",
    "docker:prod:down": "docker compose down",
    "docker:clean": "docker compose down -v --rmi local && docker compose -f docker-compose.dev.yml down -v --rmi local",
    "studio": "npm run studio --workspace=backend",
    "console": "npm run console --workspace=backend",
    "lock:backend": "./backend/scripts/generate-lock.sh",
    "lock:frontend": "./frontend/scripts/generate-lock.sh",
    "audit": "npm audit",
    "audit:prod": "npm audit --omit=dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20",
    "npm": ">=11.10.1"
  },
  "overrides": {
    "lodash": "^4.17.23",
    "hono": "^4.11.7",
    "tmp": "^0.2.4",
    "minimatch": "^10.2.3"
  }
}
